# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/
.venv/
venv/
env/
ENV/

# ── Test & coverage ───────────────────────────────────────────────────────────
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.staging
.env.production
.env.test
# .env.example is intentionally NOT listed — keep it committed
*.pem
*.key

# ── Helm / SOPS secrets ───────────────────────────────────────────────────────
# values-secrets.yaml.example — committed (plaintext template, no real values)
# values-secrets.yaml          — committed (SOPS-encrypted ciphertext, safe)
# values-secrets.yaml.dec      — NOT committed (helm-secrets plaintext temp file)
*.dec

# ── Runtime data ──────────────────────────────────────────────────────────────
backend/data/
*.db
*.sqlite
*.sqlite3

# ── Vector stores ─────────────────────────────────────────────────────────────
chroma_data/
qdrant_data/

# ── Frontend ──────────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/coverage/
frontend/.eslintcache
*.tsbuildinfo

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Codegraph index ───────────────────────────────────────────────────────────
.codegraph/

# ── Claude local settings (session-specific allowlists, not for sharing) ──────
.claude/settings.local.json

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
