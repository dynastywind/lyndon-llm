# deploy/values-secrets.yaml.example
#
# Plaintext template for SOPS-encrypted Helm secrets.
# Commit this file as-is (no real values).
# The encrypted deploy/values-secrets.yaml IS also committed (SOPS makes it safe).
#
# ── First-time setup ─────────────────────────────────────────────────────────
#
#   # Install tools (macOS)
#   brew install age sops
#   helm plugin install https://github.com/jkroepke/helm-secrets
#
#   # Generate an age key pair (skip if you already have one at ~/.config/sops/age/keys.txt)
#   age-keygen -o ~/.config/sops/age/keys.txt
#   # → prints: Public key: age1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
#   # Paste that public key into .sops.yaml (replace the age1REPLACE_WITH… placeholder)
#
# ── Create and encrypt the secrets file ──────────────────────────────────────
#
#   cp deploy/values-secrets.yaml.example deploy/values-secrets.yaml
#   # Edit deploy/values-secrets.yaml — fill in your real values below
#   sops --encrypt --in-place deploy/values-secrets.yaml
#   git add deploy/values-secrets.yaml    # safe to commit — values are ciphertext
#
# ── Rotate / edit secrets later ──────────────────────────────────────────────
#
#   sops deploy/values-secrets.yaml       # opens $EDITOR, re-encrypts on save
#
# ── Deploy ───────────────────────────────────────────────────────────────────
#
#   helm secrets install lyndon-llm ./deploy \
#     -f deploy/values.yaml \
#     -f deploy/values-secrets.yaml
#
#   # Upgrade:
#   helm secrets upgrade lyndon-llm ./deploy \
#     -f deploy/values.yaml \
#     -f deploy/values-secrets.yaml
#
# ── CI / CD ──────────────────────────────────────────────────────────────────
#
#   Store the private key as a CI secret named SOPS_AGE_KEY, then in the pipeline:
#     export SOPS_AGE_KEY="$SOPS_AGE_KEY"   # helm-secrets picks this up automatically
#     helm secrets upgrade --install lyndon-llm ./deploy \
#       -f deploy/values.yaml \
#       -f deploy/values-secrets.yaml
#
# ─────────────────────────────────────────────────────────────────────────────

backend:
  secrets:
    # LLM provider API key.
    # Leave empty ("") when using a local Ollama instance (no key required).
    llmApiKey: ""

    # Embedding provider API key.
    # Leave empty ("") when using a local Ollama instance.
    embeddingApiKey: ""

    # Langfuse observability keys — find these in your Langfuse project settings.
    # Leave both empty ("") to disable Langfuse tracing.
    langfusePublicKey: ""    # pk-lf-…
    langfuseSecretKey: ""    # sk-lf-…

    # JWT signing key — REQUIRED.
    # Generate a strong random key:
    #   openssl rand -hex 32
    jwtSecretKey: ""

    # Qdrant API key.
    # Leave empty ("") to run Qdrant without authentication (fine for private clusters).
    qdrantApiKey: ""

    # GitHub OAuth App credentials — enables "Continue with GitHub" login.
    # Create an OAuth App at https://github.com/settings/developers with the
    # callback URL <FRONTEND_URL>/api/auth/github/callback.
    # Leave both empty ("") to disable GitHub login.
    githubClientId: ""       # e.g. Iv23li…
    githubClientSecret: ""
