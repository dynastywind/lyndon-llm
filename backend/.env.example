# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:52415/v1
LLM_API_KEY=local
LLM_MODEL=local-model          # replace with your actual model name, e.g. llama3.2

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:52415/v1
EMBEDDING_API_KEY=local
EMBEDDING_DIMENSION=768

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE_BACKEND=chroma    # chroma | qdrant
CHROMA_HOST=localhost
CHROMA_PORT=8001
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/lyndon.db

# ── Web Search ────────────────────────────────────────────────────────────────
WEB_SEARCH_PROVIDER=tavily     # tavily | serpapi
TAVILY_API_KEY=
SERPAPI_API_KEY=

# ── Code Block ────────────────────────────────────────────────────────────────
CODE_DEFAULT_REPO_PATH=
VERCEL_TOKEN=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
API_PORT=8000
