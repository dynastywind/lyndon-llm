# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | production
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:52415/v1
LLM_API_KEY=local
LLM_MODEL=local-model          # e.g. llama3.2, mlx-community/Llama-3.2-3B-Instruct-8bit
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_STREAM=true

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:52415/v1
EMBEDDING_API_KEY=local
EMBEDDING_DIMENSION=768

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE_BACKEND=chroma    # chroma | qdrant
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./data/chroma
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/lyndon.db

# ── Web Search ────────────────────────────────────────────────────────────────
WEB_SEARCH_PROVIDER=duckduckgo # duckduckgo | google | tavily | serpapi
WEB_SEARCH_MAX_RESULTS=5
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
TAVILY_API_KEY=
SERPAPI_API_KEY=

# ── Code Block ────────────────────────────────────────────────────────────────
CODE_DEFAULT_REPO_PATH=
VERCEL_TOKEN=

# ── Cowork ────────────────────────────────────────────────────────────────────
COWORK_SHELL_TIMEOUT=30
COWORK_MAX_PLAN_STEPS=20

# ── Sandbox ───────────────────────────────────────────────────────────────────
SANDBOX_TIMEOUT=60

# ── Memory ────────────────────────────────────────────────────────────────────
SHORT_TERM_MAX_TOKENS=6000
LONG_TERM_TOP_K=5
MEMORY_CONSOLIDATION_INTERVAL=10

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=6
RAG_BM25_WEIGHT=0.3

# ── Chat Orchestrator ─────────────────────────────────────────────────────────
ORCHESTRATOR_ENABLED=true
ORCHESTRATOR_STRATEGY=heuristic  # heuristic | llm

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=86400

# ── Langfuse Observability ────────────────────────────────────────────────────
# Get keys from your Langfuse project → Settings → API Keys
# Supported hosts: https://cloud.langfuse.com (US) | https://eu.cloud.langfuse.com | https://jp.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://jp.cloud.langfuse.com
